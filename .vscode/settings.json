{
  "[luau]": {
    "editor.defaultFormatter": "JohnnyMorganz.stylua",
    "editor.formatOnSave": true
  },
  "cSpell.words": [
    "fwdebug",
    "fwfatal",
    "fwinfo",
    "fwwarn",
    "getmetatable",
    "Insertable",
    "metatable",
    "newindex",
    "RAFECLASS",
    "rawget",
    "rawset",
    "rbxassetid",
    "studiocomponents"
  ],
  "stylua.targetReleaseVersion": "latest",
  "luau-lsp.fflags.enableNewSolver": true,
  "files.exclude": {
    "build/": true,
    "static-build/": true
  },
  "luau-lsp.types.definitionFiles": {
    "0": "C:/LuauDefinitionFiles/globalTypes.d.lua",
    "1": "./typedefs/globalTypes.d.lua",
  }
}
